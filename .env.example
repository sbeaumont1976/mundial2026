# Copia este archivo a .env.local y rellena con tus valores de Supabase.
# La ANON KEY está diseñada para ser pública en el frontend: NO es un secreto
# siempre que actives Row Level Security (RLS) con SOLO políticas de SELECT.
# NUNCA pongas aquí la service_role key.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica
